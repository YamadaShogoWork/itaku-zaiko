@using Microsoft.AspNetCore.Identity
@inject SignInManager<Zaiko.Models.ApplicationUser> SignInManager
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Nav(string name) => ctrl == name ? "nav-item active" : "nav-item";
}
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] — 委託販売管理システム</title>
  <link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="app-layout">

  <!-- サイドバー -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 6l4-2 2 2a3 3 0 0 0 6 0l2-2 4 2-2 4h-2v8H7v-8H5L3 6z"/>
        </svg>
      </div>
      <span class="sidebar-logo-text">委託販売<br>管理システム</span>
    </div>

    <span class="nav-section-label">メイン</span>
    <a class="@Nav("Dashboard")" asp-controller="Dashboard" asp-action="Index">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      ダッシュボード
    </a>

    <span class="nav-section-label">マスタ</span>
    <a class="@Nav("Client")" asp-controller="Client" asp-action="Index">
      <svg viewBox="0 0 24 24"><path d="M3 9h18M3 15h18M9 3v18"/></svg>
      取引先
    </a>
    <a class="@Nav("Product")" asp-controller="Product" asp-action="Index">
      <svg viewBox="0 0 24 24"><path d="M3 6l4-2 2 2a3 3 0 0 0 6 0l2-2 4 2-2 4h-2v8H7v-8H5L3 6z"/></svg>
      商品
    </a>
    <a class="@Nav("Color")" asp-controller="Color" asp-action="Index">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M3 12h3m12 0h3M12 3v3m0 12v3"/></svg>
      色
    </a>

    <span class="nav-section-label">業務</span>
    <a class="@Nav("Delivery")" asp-controller="Delivery" asp-action="Index">
      <svg viewBox="0 0 24 24"><path d="M5 8h14M5 12h14M5 16h6"/><rect x="3" y="4" width="18" height="16" rx="2"/></svg>
      納品登録
    </a>
    <a class="@Nav("DeliveryHistory")" asp-controller="DeliveryHistory" asp-action="Index">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
      納品履歴
    </a>
    <a class="@Nav("SalesReport")" asp-controller="SalesReport" asp-action="Index">
      <svg viewBox="0 0 24 24"><path d="M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 4h12M10 4v4"/></svg>
      売上報告入力
    </a>
    <a class="@Nav("SalesReportHistory")" asp-controller="SalesReportHistory" asp-action="Index">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
      売上報告履歴
    </a>

    <span class="nav-section-label">設定</span>
    <a class="@Nav("Users")" asp-controller="Users" asp-action="Index">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      ユーザー管理
    </a>

    @if (SignInManager.IsSignedIn(User))
    {
      <div style="margin-top:auto;padding:var(--spacing-lg);border-top:0.5px solid var(--color-border);">
        <div class="flex-center gap-sm">
          <div style="width:32px;height:32px;border-radius:50%;background:var(--color-accent-light);display:flex;align-items:center;justify-content:center;font-size:var(--font-size-sm);font-weight:500;color:var(--color-accent);flex-shrink:0;">
            @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")
          </div>
          <div>
            <div style="font-size:var(--font-size-sm);font-weight:500;">@User.Identity?.Name</div>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="display:inline;">
              <button type="submit" style="background:none;border:none;padding:0;font-size:var(--font-size-xs);color:var(--color-text-muted);cursor:pointer;text-decoration:underline;">ログアウト</button>
            </form>
          </div>
        </div>
      </div>
    }
  </nav>

  <!-- メインコンテンツ -->
  <main class="main-content">

    @if (TempData["Success"] is string successMsg)
    {
      <div id="toast" style="position:fixed;bottom:24px;right:24px;background:var(--color-success-bg);color:var(--color-success-text);padding:12px 20px;border-radius:var(--radius-md);font-size:var(--font-size-sm);box-shadow:0 2px 8px rgba(0,0,0,0.15);z-index:9999;">@successMsg</div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
      <div id="toast" style="position:fixed;bottom:24px;right:24px;background:var(--color-danger-bg);color:var(--color-danger-text);padding:12px 20px;border-radius:var(--radius-md);font-size:var(--font-size-sm);box-shadow:0 2px 8px rgba(0,0,0,0.15);z-index:9999;">@errorMsg</div>
    }

    @RenderBody()

  </main>
</div>

<!-- ダイアログ（共通） -->
<div id="dialog-overlay" class="dialog-overlay" hidden>
  <div class="dialog-box">
    <div id="dialog-icon-wrap" class="dialog-icon-wrap confirm">
      <svg id="dialog-icon-svg" viewBox="0 0 24 24"></svg>
    </div>
    <div id="dialog-title" class="dialog-title"></div>
    <div id="dialog-message" class="dialog-message"></div>
    <div id="dialog-buttons" class="dialog-buttons"></div>
  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
  const toast = document.getElementById('toast');
  if (toast) setTimeout(() => toast.remove(), 3000);
</script>
</body>
</html>
