@model Zaiko.ViewModels.UserEditViewModel
@{
    ViewData["Title"] = Model.UserId != null ? "ユーザー編集" : "ユーザー登録";
    bool isNew = Model.UserId == null;
}

@section Styles {
<style>
.form-section { margin-bottom: var(--spacing-lg); max-width: 480px; }
.required-mark { color: var(--color-danger-text); }
.field-error { font-size: var(--font-size-sm); color: var(--color-danger-text); display: block; }
.form-actions { display: flex; gap: var(--spacing-md); margin-top: var(--spacing-lg); }
.form-hint { font-size: var(--font-size-sm); color: var(--color-text-muted); margin-top: var(--spacing-xs); }
</style>
}

<div class="page-header">
  <h1 class="page-title">@ViewData["Title"]</h1>
</div>

<form asp-controller="Users" asp-action="Edit" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="UserId" />

  <div class="card form-section">
    <div asp-validation-summary="ModelOnly" class="field-error" style="margin-bottom:var(--spacing-md);"></div>

    <div class="form-group">
      <label asp-for="UserName" class="form-label">
        ユーザー名 <span class="required-mark">*</span>
      </label>
      <input asp-for="UserName" class="form-input" autocomplete="username" id="user-name-input" />
      <span asp-validation-for="UserName" class="field-error"></span>
      <span id="user-name-dup-warn" style="display:none;font-size:var(--font-size-sm);color:var(--color-warning-text);">同名のユーザーが既に登録されています</span>
    </div>

    <div class="form-group">
      <label asp-for="Password" class="form-label">
        パスワード
        @if (isNew) { <span class="required-mark">*</span> }
      </label>
      <input asp-for="Password" type="password" class="form-input" autocomplete="new-password"
             placeholder="@(isNew ? "" : "変更しない場合は空欄")" />
      <span asp-validation-for="Password" class="field-error"></span>
      @if (!isNew)
      {
        <span class="form-hint">空欄のままにするとパスワードは変更されません</span>
      }
    </div>

    <div class="form-group">
      <label asp-for="ConfirmPassword" class="form-label">パスワード（確認）</label>
      <input asp-for="ConfirmPassword" type="password" class="form-input" autocomplete="new-password"
             placeholder="@(isNew ? "" : "変更しない場合は空欄")" />
      <span asp-validation-for="ConfirmPassword" class="field-error"></span>
    </div>

    <div class="form-actions">
      <a href="@Url.Action("Index")" class="btn btn-secondary">キャンセル</a>
      <button type="submit" class="btn btn-primary">保存する</button>
    </div>
  </div>
</form>

@section Scripts {
@await Html.PartialAsync("_ValidationScriptsPartial")
<script>
(function() {
    var inp = document.getElementById('user-name-input');
    var warn = document.getElementById('user-name-dup-warn');
    if (!inp || !warn) return;
    var currentId = '@(Model.UserId ?? "")';
    inp.addEventListener('blur', function() {
        var name = inp.value.trim();
        if (!name) { warn.style.display = 'none'; return; }
        var url = '@Url.Action("CheckDuplicate", "Users")?name=' + encodeURIComponent(name)
                + (currentId ? '&currentId=' + currentId : '');
        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(d) { warn.style.display = d.exists ? '' : 'none'; })
            .catch(function() {});
    });
})();
</script>
}
